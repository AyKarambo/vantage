{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": []
  },
  // Only `shared/contract` is renderer-facing. Other `shared/` subtrees are
  // main↔bridge plumbing that legitimately uses Node APIs (Buffer, process),
  // which this project must never compile — `types: []` above is what keeps the
  // renderer bundle CSP-friendly and Node-free. Anything the renderer genuinely
  // imports is still pulled in transitively, so this narrows the seed set only.
  "include": ["src/**/*", "preview/**/*", "../src/shared/contract/**/*"]
}
