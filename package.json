{
  "name": "overwatch-gametracker-sync",
  "version": "0.1.0",
  "description": "Account-safe auto-sync of Overwatch 2 matches into a Notion Gametracker database by reading Counterwatch's local data.",
  "author": "Timo Seikel",
  "license": "MIT",
  "main": "dist/main/index.js",
  "overwolf": {
    "packages": [
      "gep"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "make-icon": "node scripts/make-tray-icon.js",
    "start": "npm run make-icon && npm run build && ow-electron .",
    "dev": "npm run make-icon && npm run build && ow-electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run make-icon && npm run build && ow-electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "com.timoseikel.owgametrackersync",
    "productName": "Overwatch Gametracker Sync",
    "asar": true,
    "nodeGypRebuild": false,
    "overwolf": {
      "disableAdOptimization": true
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "appsettings.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/appicon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Overwatch Gametracker Sync"
    }
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "latest",
    "@overwolf/ow-electron-builder": "latest",
    "@overwolf/ow-electron-packages-types": "^0.0.5",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
