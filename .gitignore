# build output
dist/
out/
release/

# `build/` is NOT output — it's ow-electron-builder's `buildResources` directory, i.e.
# installer *inputs* (the NSIS license page). Ignore anything that lands there by
# accident, but keep the files the installer is built from.
build/*
!build/license.txt

# renderer bundles (esbuild output; renderer/dist is covered by dist/ above)
renderer/preview/preview.js
renderer/preview/preview.js.map

# generated from CHANGELOG.md by scripts/build-changelog.mjs (run by typecheck + every
# build, so it can't drift — and so it never needs reviewing in a diff)
renderer/src/generated/

# deps
node_modules/

# local runtime config & secrets (never commit)
config.local.json
*.local
.env
.env.*
secrets/
*.secret

# spec-driven-development gate files (specs live in GitHub issues, not the tree)
.claude/sdd/

# generated icons (created by scripts/make-tray-icon.mjs)
assets/tray.png
assets/appicon.png

# generated Overwolf store assets (npm run assets:store / assets:screens)
assets/store/

# logs
*.log
npm-debug.log*

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
