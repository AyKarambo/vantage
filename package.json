{
  "name": "ow.vantage",
  "version": "0.1.0",
  "description": "Vantage — an account-safe Overwatch stats coach. Turns match history into priority maps, hero stats, mental tracking and improvement targets, with optional Notion export.",
  "author": "Timo Seikel",
  "license": "MIT",
  "main": "dist/main/index.js",
  "overwolf": {
    "packages": [
      "gep"
    ]
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && npm run build:renderer",
    "build:renderer": "node scripts/build-renderer.mjs",
    "watch:renderer": "node scripts/build-renderer.mjs --watch",
    "build:preview": "node scripts/build-preview.mjs",
    "preview": "node scripts/build-preview.mjs && node scripts/preview-server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p renderer/tsconfig.json",
    "make-icon": "node scripts/make-tray-icon.mjs",
    "assets:store": "node scripts/make-store-assets.mjs",
    "assets:screens": "npm run build:preview && ow-electron scripts/capture-screenshots.cjs",
    "assets:app-screens": "npm run build && ow-electron scripts/capture-app-screenshots.cjs",
    "start": "npm run make-icon && npm run build && ow-electron .",
    "dev": "npm run make-icon && npm run build && ow-electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run make-icon && npm run build && ow-electron-builder --win --x64 --publish=never",
    "publish:release": "powershell -ExecutionPolicy Bypass -File scripts/publish-release.ps1",
    "release:check": "node scripts/next-version.mjs --check",
    "import:obsidian": "powershell -ExecutionPolicy Bypass -File scripts/import-obsidian.ps1",
    "pack:opk": "node scripts/pack-opk.mjs",
    "make:winget": "node scripts/make-winget-manifest.mjs"
  },
  "build": {
    "appId": "com.timoseikel.vantage",
    "productName": "Vantage",
    "asar": true,
    "nodeGypRebuild": false,
    "overwolf": {
      "disableAdOptimization": true
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "!renderer/preview/**",
      "!renderer/**/*.map",
      "assets/**/*",
      "!assets/store/**",
      "appsettings.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/appicon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signtoolOptions": {
        "sign": "./scripts/certum-sign.cjs",
        "certificateSha1": "69310A558F482846DB5BF3A35531159E483BAEBF",
        "rfc3161TimeStampServer": "http://time.certum.pl",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "publisherName": "Open Source Developer Timo Seikel"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Vantage"
    }
  },
  "dependencies": {
    "@notionhq/client": "^5.22.0"
  },
  "devDependencies": {
    "@overwolf/ow-cli": "^0.1.6",
    "@overwolf/ow-electron": "39.8.10-beta.12",
    "@overwolf/ow-electron-builder": "26.9.0-beta.5",
    "@overwolf/ow-electron-packages-types": "^1.1.4",
    "@types/node": "^22.20.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@overwolf/ow-electron@39.8.10-beta.12": true,
    "@overwolf/ow-cli@0.1.6": true
  }
}
