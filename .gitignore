# build output
dist/
build/
out/
release/

# renderer bundles (esbuild output; renderer/dist is covered by dist/ above)
renderer/preview/preview.js
renderer/preview/preview.js.map

# deps
node_modules/

# local runtime config & secrets (never commit)
config.local.json
*.local
.env
.env.*
secrets/
*.secret

# spec-driven-development gate files (specs live in GitHub issues, not the tree)
.claude/sdd/

# generated icons (created by scripts/make-tray-icon.mjs)
assets/tray.png
assets/appicon.png

# generated Overwolf store assets (npm run assets:store / assets:screens)
assets/store/

# logs
*.log
npm-debug.log*

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
