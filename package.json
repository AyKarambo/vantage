{
  "name": "ow.vantage",
  "version": "0.1.0",
  "description": "Vantage — an account-safe Overwatch 2 stats coach. Turns match history into priority maps, hero stats, mental tracking and improvement targets, with optional Notion export.",
  "author": "Timo Seikel",
  "license": "MIT",
  "main": "dist/main/index.js",
  "overwolf": {
    "packages": [
      "gep"
    ]
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && npm run build:renderer",
    "build:renderer": "node scripts/build-renderer.mjs",
    "watch:renderer": "node scripts/build-renderer.mjs --watch",
    "build:preview": "node scripts/build-preview.mjs",
    "preview": "node scripts/build-preview.mjs && node scripts/preview-server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p renderer/tsconfig.json",
    "make-icon": "node scripts/make-tray-icon.mjs",
    "assets:store": "node scripts/make-store-assets.mjs",
    "assets:screens": "npm run build:preview && ow-electron scripts/capture-screenshots.cjs",
    "start": "npm run make-icon && npm run build && ow-electron .",
    "dev": "npm run make-icon && npm run build && ow-electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run make-icon && npm run build && ow-electron-builder --win --x64 --publish=never",
    "sign:local": "powershell -ExecutionPolicy Bypass -File scripts/sign-local.ps1",
    "pack:opk": "node scripts/pack-opk.mjs"
  },
  "build": {
    "appId": "com.timoseikel.vantage",
    "productName": "Vantage",
    "asar": true,
    "nodeGypRebuild": false,
    "overwolf": {
      "disableAdOptimization": true
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "!renderer/preview/**",
      "!renderer/**/*.map",
      "assets/**/*",
      "!assets/store/**",
      "appsettings.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/appicon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Vantage"
    }
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "39.6.1",
    "@overwolf/ow-electron-builder": "26.8.5",
    "@overwolf/ow-electron-packages-types": "^0.0.5",
    "@types/node": "^20.11.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@overwolf/ow-electron@39.6.1": true
  }
}
