{
  "compilerOptions": {
    // TS6 deprecates "Node"/baseUrl (removed in TS7); the sanctioned escape hatch
    // per https://aka.ms/ts6 while a real migration to NodeNext (which changes
    // extension/exports-field resolution semantics — a separate, deliberate
    // project, not a drive-by dependency bump) is still pending.
    "ignoreDeprecations": "6.0",
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021"],
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "electron": ["node_modules/@overwolf/ow-electron/electron"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src"],
  // `src/mcp` is the MCP bridge: a separate, esbuild-bundled entrypoint that
  // imports @modelcontextprotocol/sdk. That package publishes its subpaths via
  // an "exports" map, which classic `moduleResolution: "Node"` above cannot
  // read — so the bridge is typechecked by tsconfig.mcp.json (bundler
  // resolution) and built by scripts/build-mcp.mjs, never by this project.
  "exclude": ["node_modules", "dist", "test", "src/mcp"]
}
